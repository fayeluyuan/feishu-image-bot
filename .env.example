# ============================================
# 飞书应用配置
# 在飞书开放平台创建应用后获取
# https://open.feishu.cn/app
# ============================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxx...xxxx

# 事件订阅加密密钥（可选，配置了才需要填）
FEISHU_ENCRYPT_KEY=

# ============================================
# Hermes 配置（云端混合模式）
# ============================================
# Hermes CLI 命令路径（云端用完整路径）
HERMES_CMD=/home/ubuntu/hermes-env/bin/hermes
HERMES_TIMEOUT=300
DEFAULT_IMAGE_TOOL=image_generate
DEFAULT_ASPECT_RATIO=portrait
ENABLE_CUSTOM_SIZE_POSTPROCESS=true

# 图片生成专用 provider/model（不修改 Hermes 全局配置）
# 生图时自动传 -m gpt-image-2-medium --provider openai-codex
HERMES_IMAGE_PROVIDER=openai-codex
HERMES_IMAGE_MODEL=gpt-image-2-medium

# ============================================
# 其他配置
# ============================================
# 服务端口
PORT=5000
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ============================================
# 烈鸟 API 配置（默认 Gemini-3-Pro 生图；指定 image2 时切换分组）
# ============================================
# 旧兼容变量可留空；推荐分别填写两个分组 key
LIENIAO_API_KEY=
LIENIAO_GEMINI_API_KEY=<烈鸟 Gemini 原生端点分组授权码>
LIENIAO_IMAGE2_API_KEY=<烈鸟 OpenAI 兼容图片端点分组授权码>
LIENIAO_DEFAULT_BACKEND=gemini
LIENIAO_GEMINI_API_URL=https://lnapi.com/v1beta/models/{model}:generateContent
LIENIAO_GEMINI_MODEL=gemini-3-pro-image-preview
LIENIAO_IMAGE2_API_URL=https://lnapi.com/v1/images/generations
LIENIAO_IMAGE2_MODEL=gpt-image-2-all
LIENIAO_TIMEOUT=180
LIENIAO_OUTPUT_DIR=/tmp/feishu-image-bot/lieniao
FALLBACK_TO_HERMES=true

# ============================================
# 飞书参考图 / 图生图缓存配置
# ============================================
REFERENCE_IMAGE_DIR=/tmp/feishu-image-bot/references
REFERENCE_IMAGE_TTL_SECONDS=1800
