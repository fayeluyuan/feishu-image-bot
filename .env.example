# ============================================
# 飞书应用配置（必填）
# 在飞书开放平台创建应用后获取
# https://open.feishu.cn/app
# ============================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 事件订阅加密密钥（可选，配置了才需要填）
FEISHU_ENCRYPT_KEY=

# ============================================
# 图片生成服务配置（至少填一个）
# 系统会自动检测你配置了哪个，就调用哪个
# 支持多个同时配置，失败时自动 fallback
# ============================================

# --- 烈鸟 Gemini（可选，支持文本生图 + 参考图）---
LIENIAO_GEMINI_API_KEY=
LIENIAO_GEMINI_MODEL=gemini-3-pro-image-preview

# --- 烈鸟 image2 / gpt-image-2（可选，文本生图）---
LIENIAO_IMAGE2_API_KEY=
LIENIAO_IMAGE2_MODEL=gpt-image-2-all

# 默认后端：gemini 或 image2
LIENIAO_DEFAULT_BACKEND=gemini

# --- OpenAI 官方（DALL-E 3，质量好但贵）---
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=dall-e-3

# --- 阿里云百炼（通义万相，国内稳定）---
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=wanx-v1

# ============================================
# 高级配置（一般不用改）
# ============================================

# 烈鸟端点地址（默认不用改）
LIENIAO_GEMINI_API_URL=https://lnapi.com/v1beta/models/{model}:generateContent
LIENIAO_IMAGE2_API_URL=https://lnapi.com/v1/images/generations
LIENIAO_TIMEOUT=180
LIENIAO_OUTPUT_DIR=/tmp/feishu-image-bot/lieniao

# OpenAI 端点（默认不用改，支持代理地址）
OPENAI_API_URL=https://api.openai.com/v1/images/generations
OPENAI_TIMEOUT=120

# 百炼端点（默认不用改）
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis
DASHSCOPE_TIMEOUT=180

# 通用输出目录
IMAGE_OUTPUT_DIR=/tmp/feishu-image-bot/images

# 自定义插件目录（放自己写的提供商插件）
# PROVIDERS_DIR=/path/to/custom/providers

# ============================================
# 参考图 / 图生图缓存配置
# ============================================
REFERENCE_IMAGE_DIR=/tmp/feishu-image-bot/references
REFERENCE_IMAGE_TTL_SECONDS=1800

# ============================================
# 服务配置
# ============================================
PORT=5000
LOG_LEVEL=INFO

# ============================================
# 以下 Hermes 配置已废弃（保留兼容，无需修改）
# ============================================
# HERMES_CMD=hermes
# HERMES_TIMEOUT=300
# DEFAULT_IMAGE_TOOL=image_generate
# DEFAULT_ASPECT_RATIO=portrait
# ENABLE_CUSTOM_SIZE_POSTPROCESS=true
# HERMES_IMAGE_PROVIDER=
# HERMES_IMAGE_MODEL=
